{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react",
    "module": "ESNext",
    "types": ["react", "node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": false,
    "isolatedModules": true,
    "noEmit": false,
    "sourceMap": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "build"]
}
